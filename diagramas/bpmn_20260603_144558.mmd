flowchart TD
    %% BPMN Diagram: Dental Clinic Consultation Process
    %% Pools represent participants: Patient, Receptionist, Dentist, Cashier

    subgraph Patient["Paciente (Paciente)"]
        direction TB
        P_start((Inicio))
        P_arrive[Llegar a la clínica]
        P_wait[Esperar en sala]
        P_consultation[Recibir consulta]
        P_treatment[Recibir tratamiento]
        P_pay[Realizar pago]
        P_end((Fin))
    end

    subgraph Reception["Recepcionista (Recepción)"]
        direction TB
        R_register[Registrar paciente en sistema]
        R_validate[Verificar datos e historia médica]
        R_complete[Completar registro y entregar ficha]
    end

    subgraph Dentist["Odontólogo (Consultorio)"]
        direction TB
        D_review[Revisar historia del paciente]
        D_examine[Realizar examen dental]
        D_diagnose[Diagnosticar y proponer tratamiento]
        D_decide{{"¿El paciente requiere tratamiento?"}}
        D_prepare[Preparar equipo e insumos]
        D_treat[Realizar tratamiento odontológico]
        D_instructions[Dar indicaciones post‑tratamiento]
    end

    subgraph Assistant["Asistente Dental"]
        direction TB
        A_assist[Asistir en el tratamiento]
        A_clean[Limpiar y esterilizar área]
    end

    subgraph Cashier["Cajero (Facturación)"]
        direction TB
        C_generate[Generar factura y detalle de gastos]
        C_collect[Cobrar y emitir comprobante]
        C_schedule[Agendar próxima cita si aplica]
    end

    %% Flujo principal – interacciones entre participantes
    P_start --> P_arrive
    P_arrive -.->|"Solicita atención"| R_register

    R_register --> R_validate
    R_validate --> R_complete
    R_complete -.->|"Informa paciente listo"| P_wait

    P_wait --> P_consultation
    P_consultation -.->|"Llamar paciente"| D_review
    D_review --> D_examine
    D_examine --> D_diagnose
    D_diagnose --> D_decide

    D_decide -- "Sí" --> D_prepare
    D_decide -- "No" --> P_end

    D_prepare --> P_treatment
    P_treatment -.->|"Iniciar procedimiento"| D_treat
    D_treat --> A_assist
    A_assist --> D_instructions
    D_instructions --> A_clean
    A_clean -.->|"Tratamiento finalizado"| C_generate

    C_generate -.->|"Entrega factura"| P_pay
    P_pay --> C_collect
    C_collect --> C_schedule
    C_schedule -.->|"Cita agendada"| P_end

    %% Fin del proceso
    P_end -->|"Salida del paciente"| P_start